server {
    listen 80;
    server_name 40.124.110.215;  # Replace with your domain or public IP

    location /impactinsights/ {
        proxy_pass http://127.0.0.1:5000/;  # Forward traffic to Gunicorn (running on localhost:5000)
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Optional: Strip the /impactinsights path before passing the request to Gunicorn
        rewrite ^/impactinsights(/.*)$ $1 break;
    }
}
